# =============================================================================
# MixBot — Configuração de Ambiente (.env)
# =============================================================================
# Copie este arquivo como .env e preencha os valores corretos.
#   cp .env.example .env
#
# Valores padrão seguros já estão definidos no código; você só precisa
# sobrescrever o que for necessário para o seu ambiente.
#
# Para IDs do Discord, use 0000000000000000000 (19 zeros) como placeholder.
# Para segredos (tokens, senhas), deixe vazio ou use "SEU_VALOR_AQUI".
# Para booleanos, use true ou false (sem aspas).
# =============================================================================

# =============================================================================
# BOT E APIS
# =============================================================================

# Token do bot no Discord Developer Portal
# (obrigatório — sem ele o bot não inicia)
DISCORD_TOKEN=

# Token alternativo (alias para DISCORD_TOKEN)
DISCORD_BOT_TOKEN=

# Chave da Steam Web API
# (https://steamcommunity.com/dev/apikey)
STEAM_API_KEY=

# Chave da API da FACEIT
FACEIT_API_KEY=

# =============================================================================
# CS2 BRIDGE — Comunicação Discord <-> Servidor CS2
# =============================================================================

# Endereço do servidor CS2 principal (fallback: POOL_S1_HOST)
RCON_HOST=
# Porta RCON do servidor principal (fallback: POOL_S1_PORT)
RCON_PORT=0
# Senha RCON do servidor principal (fallback: POOL_S1_RCON_PASSWORD)
RCON_PASSWORD=

# Canal para alertas de admin via bridge
DISCORD_ADMIN_ALERT_CHANNEL_ID=0000000000000000000
# Canal para alertas de "completer" (call-admin resolvido)
DISCORD_COMPLETER_ALERT_CHANNEL_ID=0000000000000000000
# Canal de entrada da bridge (CS2 -> Discord)
CS2_BRIDGE_INBOX_CHANNEL_ID=0000000000000000000
# Canal de relay de chat (fallback: CANAL_MONITOR_ID)
DISCORD_CHAT_RELAY_CHANNEL_ID=0000000000000000000

# ID do cargo de "call-admin" no Discord
DISCORD_CALLADMIN_ROLE_ID=0000000000000000000
# ID do cargo de "completer" no Discord
DISCORD_COMPLETER_ROLE_ID=0000000000000000000

# Segredo compartilhado entre CS2 e Discord (autenticação da bridge)
CS2_SHARED_KEY=

# Chave de autenticação do webhook do MatchZy
MATCHZY_WEBHOOK_KEY=

# SteamID64 do administrador do MatchZy
MATCHZY_ADMIN_STEAMID64=

# =============================================================================
# BANCO DE DADOS PRINCIPAL (MySQL / MariaDB)
# =============================================================================

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=bot
DB_USER=
DB_PASSWORD=

# =============================================================================
# WEBAPP — Sync de Ranking (opcional)
# =============================================================================
# Quando configurado, o bot espelha resultados para o banco do painel web.
# Se não configurado, usa os valores DB_* como fallback.

WEBAPP_DB_HOST=
WEBAPP_DB_PORT=3306
WEBAPP_DB_USER=
WEBAPP_DB_PASSWORD=
WEBAPP_DB_NAME=

# =============================================================================
# WEB SERVER — Healthcheck
# =============================================================================

# Porta do servidor HTTP para health check (/health)
PORT=10000

# =============================================================================
# SERVIDOR CS2 PRINCIPAL — RETAKE
# =============================================================================

RETAKE_HOST=
RETAKE_PORT=27015
RETAKE_RCON_PASSWORD=

# =============================================================================
# CANAIS DO DISCORD (IDs)
# =============================================================================
# Substitua os 0000000000000000000 pelos IDs reais dos canais do seu servidor.

CANAL_FILA_ID=0000000000000000000
CANAL_LOGS_ID=0000000000000000000
CANAL_RANKING_ID=0000000000000000000
CANAL_GERAL_ID=0000000000000000000
CANAL_RESUMO_ID=0000000000000000000
CANAL_SKINS_ID=0000000000000000000
SKINS_ACTIVITY_APPLICATION_ID=0000000000000000000
CANAL_STEAMID_ID=0000000000000000000
CANAL_MONITOR_ID=0000000000000000000
CANAL_AJUDA_ID=0000000000000000000
CANAL_APOIO_ID=0000000000000000000
CANAL_DENUNCIAS_ID=0000000000000000000
CANAL_PUNICOES_ID=0000000000000000000
CANAL_BOAS_VINDAS_ID=0000000000000000000
CANAL_PAINEL_TICKETS_ID=0000000000000000000
CANAL_PAINEL_PUNICOES_ID=0000000000000000000
SALA_PROXIMO_ID=0000000000000000000
SALA_SAIDA_ID=0000000000000000000
TORNEIO_CATEGORY_ID=0000000000000000000
TORNEIO_PICKS_BANS_CHANNEL_ID=0000000000000000000
TOURN_GROUPS_CHANNEL_ID=0000000000000000000
TOURN_SCHEDULE_CHANNEL_ID=0000000000000000000
TICKET_CATEGORY_ID=0000000000000000000
TICKET_ARCHIVE_CATEGORY_ID=0000000000000000000

# =============================================================================
# CARGOS DO DISCORD (IDs)
# =============================================================================

# ID do cargo de membro comum (fallback: 0 = desativado)
MEMBER_ROLE_ID=0000000000000000000
# Nome do cargo de membro (fallback: "Membro")
MEMBER_ROLE_NAME=Membro

# IDs dos cargos de staff (separados por vírgula)
STAFF_ROLE_IDS=
# IDs dos cargos VIP (separados por vírgula)
VIP_ROLE_IDS=

# =============================================================================
# SFTP — Transferência de Arquivos para Servidores CS2
# =============================================================================

SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
# Caminho absoluto para a chave privada (ex: C:/Users/.ssh/id_rsa)
SFTP_PRIVATE_KEY=
# Senha SFTP (usada apenas se SFTP_PRIVATE_KEY não estiver definida)
SFTP_PASSWORD=
SFTP_TIMEOUT=15
SFTP_DEBUG=false

# =============================================================================
# FTP — Torneios (Configs Remotas)
# =============================================================================

TOURN_FTP_HOST=
TOURN_FTP_USER=
TOURN_FTP_PASS=
TOURN_FTP_PORT=21
TOURN_FTP_TLS=false
TOURN_FTP_TIMEOUT=20
# Diretório remoto para arquivos de configuração de torneios
TOURN_REMOTE_CFG_DIR=cfg/MatchZy

# =============================================================================
# MATCHZY — Execução Local de Servidores
# =============================================================================

# Diretório base dos configs do MatchZy no servidor
MATCHZY_BASE_DIR=
# Subdiretório para arquivos de partidas (relativo ao base dir)
MATCHZY_MATCHES_SUBDIR=matches
# Caminho base para carregar configs (relativo ao cfg do CS2)
MATCHZY_LOAD_BASE=cfg/MatchZy

# Usuário sudo para executar scripts de runtime
RUNTIME_SUDO_USER=cs2
# Atraso inicial antes de verificar se o servidor subiu (segundos)
RUNTIME_BOOT_DELAY_SECONDS=2.0
# Timeout para subprocessos do runtime (segundos)
RUNTIME_SUBPROCESS_TIMEOUT=30
# Timeout máximo para o servidor ficar online (segundos)
RUNTIME_START_TIMEOUT_SECONDS=30
# Período de graça antes de considerar o servidor offline (segundos)
RUNTIME_ONLINE_GRACE_SECONDS=30

# =============================================================================
# POOL DE SERVIDORES (S1 a S5)
# =============================================================================
# Defina os IDs dos servidores que estarão ativos no pool.
# Padrão: 1,2,3,4,5
POOL_SERVER_IDS=1,2,3,4,5

# Para cada servidor (substitua N pelo número: 1, 2, 3, 4, 5):
# POOL_S{N}_ENABLED=true          # Ativo ou não
# POOL_S{N}_NAME=SERVER #01       # Nome de exibição
# POOL_S{N}_FLAG=                 # Emoji de bandeira (ex: 🇫🇷)
# POOL_S{N}_RUNTIME_ID=mix{N}     # Identificador único de runtime
# POOL_S{N}_START_SCRIPT=         # Caminho do script de inicialização
# POOL_S{N}_STOP_SCRIPT=          # Caminho do script de parada (opcional)
# POOL_S{N}_SERVICE_NAME=         # Nome do serviço systemd (opcional)
# POOL_S{N}_TMUX_SESSION=mix{N}   # Nome da sessão tmux
# POOL_S{N}_HOST=                 # Endereço IP do servidor
# POOL_S{N}_PORT=                 # Porta do game
# POOL_S{N}_GOTV_PORT=            # Porta do GOTV
# POOL_S{N}_RCON_PASSWORD=        # Senha RCON
# POOL_S{N}_MODES=mix,tourney     # Modos habilitados (separados por vírgula)
# POOL_S{N}_PICKS_TEXT_ID=        # ID do canal de texto para picks
# POOL_S{N}_PICKS_VOICE_ID=       # ID do canal de voz para picks
# POOL_S{N}_TEAM1_VOICE_ID=       # ID do canal de voz do time 1
# POOL_S{N}_TEAM2_VOICE_ID=       # ID do canal de voz do time 2
# POOL_S{N}_CATEGORY_ID=          # ID da categoria dos canais

# Exemplo para servidor 1:
POOL_S1_ENABLED=true
POOL_S1_NAME=SERVER #01
POOL_S1_FLAG=
POOL_S1_RUNTIME_ID=mix1
POOL_S1_START_SCRIPT=
POOL_S1_TMUX_SESSION=mix1
POOL_S1_HOST=
POOL_S1_PORT=27015
POOL_S1_GOTV_PORT=27020
POOL_S1_RCON_PASSWORD=
POOL_S1_MODES=mix,tourney
POOL_S1_PICKS_TEXT_ID=0000000000000000000
POOL_S1_PICKS_VOICE_ID=0000000000000000000
POOL_S1_TEAM1_VOICE_ID=0000000000000000000
POOL_S1_TEAM2_VOICE_ID=0000000000000000000
POOL_S1_CATEGORY_ID=0000000000000000000

# =============================================================================
# SERVIDORES DE TORNEIO (TS1 a TS5)
# =============================================================================
# Para cada servidor de torneio (substitua N pelo número: 1..5):
# TS{N}_ACTIVE=false              # Ativo ou não
# TS{N}_NAME=TOURN SERVER #0{N}   # Nome de exibição
# TS{N}_HOST=                     # Endereço IP
# TS{N}_PORT=                     # Porta do game
# TS{N}_RCON_PASSWORD=            # Senha RCON
# TS{N}_GOTV_PORT=                # Porta do GOTV

# Exemplo para servidor 1:
TS1_ACTIVE=false
TS1_NAME=TOURN SERVER #01
TS1_HOST=
TS1_PORT=27015
TS1_RCON_PASSWORD=
TS1_GOTV_PORT=27020

# =============================================================================
# URLS DE MÍDIAS SOCIAIS
# =============================================================================

WHATSAPP_GROUP_URL=
STEAM_GROUP_URL=
INSTAGRAM_URL=

# =============================================================================
# UPLOAD DE DEMOS
# =============================================================================

# Endpoint para upload de demos (opcional — deixe vazio para desabilitar)
DEMO_UPLOAD_URL=

# URL base pública para download de demos (opcional — ex: https://seu-dominio.com/demos)
DEMO_DOWNLOAD_URL=

# =============================================================================
# RANKING / FILA
# =============================================================================

# Fuso horário para reset de prioridade na fila (ex: Europe/Lisbon)
QUEUE_PRIORITY_TIMEZONE=Europe/Lisbon
# Hora do dia para resetar a prioridade (0-23)
QUEUE_PRIORITY_RESET_HOUR=8
# Data de início da temporada atual (YYYY-MM-DD)
SEASON_START_DATE=2026-03-01

# =============================================================================
# WEBHOOK — Integração Stripe (opcional)
# =============================================================================

# Porta do webhook HTTP para notificações do Stripe
WEBHOOK_PORT=8765
