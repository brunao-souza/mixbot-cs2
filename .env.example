# =============================================================================
# MixBot — Environment Configuration (.env)
# =============================================================================
# Copy this file as .env and fill in the correct values.
#   cp .env.example .env
#
# Safe default values are already defined in the code; you only need
# to override what is necessary for your environment.
#
# For Discord IDs, use 0000000000000000000 (19 zeros) as placeholder.
# For secrets (tokens, passwords), leave empty or use "YOUR_VALUE_HERE".
# For booleans, use true or false (no quotes).
# =============================================================================

# =============================================================================
# BOT AND APIS
# =============================================================================

# Bot token from the Discord Developer Portal
# (required — without it the bot won't start)
DISCORD_TOKEN=

# Alternative token (alias for DISCORD_TOKEN)
DISCORD_BOT_TOKEN=

# Steam Web API Key
# (https://steamcommunity.com/dev/apikey)
STEAM_API_KEY=

# FACEIT API Key
FACEIT_API_KEY=

# =============================================================================
# CS2 BRIDGE — Discord <-> CS2 Server Communication
# =============================================================================

# Main CS2 server address (fallback: POOL_S1_HOST)
RCON_HOST=
# Main server RCON port (fallback: POOL_S1_PORT)
RCON_PORT=0
# Main server RCON password (fallback: POOL_S1_RCON_PASSWORD)
RCON_PASSWORD=

# Channel for admin alerts via bridge
DISCORD_ADMIN_ALERT_CHANNEL_ID=0000000000000000000
# Channel for completer alerts (resolved call-admin)
DISCORD_COMPLETER_ALERT_CHANNEL_ID=0000000000000000000
# Bridge inbox channel (CS2 -> Discord)
CS2_BRIDGE_INBOX_CHANNEL_ID=0000000000000000000
# Chat relay channel (fallback: CANAL_MONITOR_ID)
DISCORD_CHAT_RELAY_CHANNEL_ID=0000000000000000000

# ID of the "call-admin" role on Discord
DISCORD_CALLADMIN_ROLE_ID=0000000000000000000
# ID of the "completer" role on Discord
DISCORD_COMPLETER_ROLE_ID=0000000000000000000

# Shared secret between CS2 and Discord (bridge authentication)
CS2_SHARED_KEY=

# MatchZy webhook authentication key
MATCHZY_WEBHOOK_KEY=

# MatchZy admin SteamID64
MATCHZY_ADMIN_STEAMID64=

# =============================================================================
# MAIN DATABASE (MySQL / MariaDB)
# =============================================================================

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=bot
DB_USER=
DB_PASSWORD=

# =============================================================================
# WEBAPP — Ranking Sync (optional)
# =============================================================================
# When configured, the bot mirrors results to the web panel database.
# If not configured, uses DB_* values as fallback.

WEBAPP_DB_HOST=
WEBAPP_DB_PORT=3306
WEBAPP_DB_USER=
WEBAPP_DB_PASSWORD=
WEBAPP_DB_NAME=

# =============================================================================
# WEB SERVER — Healthcheck
# =============================================================================

# HTTP server port for health check (/health)
PORT=10000

# =============================================================================
# MAIN CS2 SERVER — RETAKE
# =============================================================================

RETAKE_HOST=
RETAKE_PORT=27015
RETAKE_RCON_PASSWORD=

# =============================================================================
# DISCORD CHANNELS (IDs)
# =============================================================================
# Replace the 0000000000000000000 with the actual channel IDs from your server.

CANAL_FILA_ID=0000000000000000000
CANAL_LOGS_ID=0000000000000000000
CANAL_RANKING_ID=0000000000000000000
CANAL_GERAL_ID=0000000000000000000
CANAL_RESUMO_ID=0000000000000000000
CANAL_SKINS_ID=0000000000000000000
SKINS_ACTIVITY_APPLICATION_ID=0000000000000000000
CANAL_STEAMID_ID=0000000000000000000
CANAL_MONITOR_ID=0000000000000000000
CANAL_AJUDA_ID=0000000000000000000
CANAL_APOIO_ID=0000000000000000000
CANAL_DENUNCIAS_ID=0000000000000000000
CANAL_PUNICOES_ID=0000000000000000000
CANAL_BOAS_VINDAS_ID=0000000000000000000
CANAL_PAINEL_TICKETS_ID=0000000000000000000
CANAL_PAINEL_PUNICOES_ID=0000000000000000000
SALA_PROXIMO_ID=0000000000000000000
SALA_SAIDA_ID=0000000000000000000
TORNEIO_CATEGORY_ID=0000000000000000000
TORNEIO_PICKS_BANS_CHANNEL_ID=0000000000000000000
TOURN_GROUPS_CHANNEL_ID=0000000000000000000
TOURN_SCHEDULE_CHANNEL_ID=0000000000000000000
TICKET_CATEGORY_ID=0000000000000000000
TICKET_ARCHIVE_CATEGORY_ID=0000000000000000000

# =============================================================================
# DISCORD ROLES (IDs)
# =============================================================================

# ID of the default member role (fallback: 0 = disabled)
MEMBER_ROLE_ID=0000000000000000000
# Name of the member role (fallback: "Membro")
MEMBER_ROLE_NAME=Membro

# Staff role IDs (comma separated)
STAFF_ROLE_IDS=
# VIP role IDs (comma separated)
VIP_ROLE_IDS=

# =============================================================================
# SFTP — File Transfer to CS2 Servers
# =============================================================================

SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
# Absolute path to the private key (e.g. C:/Users/.ssh/id_rsa)
SFTP_PRIVATE_KEY=
# SFTP password (used only if SFTP_PRIVATE_KEY is not set)
SFTP_PASSWORD=
SFTP_TIMEOUT=15
SFTP_DEBUG=false

# =============================================================================
# FTP — Tournaments (Remote Configs)
# =============================================================================

TOURN_FTP_HOST=
TOURN_FTP_USER=
TOURN_FTP_PASS=
TOURN_FTP_PORT=21
TOURN_FTP_TLS=false
TOURN_FTP_TIMEOUT=20
# Remote directory for tournament configuration files
TOURN_REMOTE_CFG_DIR=cfg/MatchZy

# =============================================================================
# MATCHZY — Local Server Execution
# =============================================================================

# Base directory for MatchZy configs on the server
MATCHZY_BASE_DIR=
# Subdirectory for match files (relative to base dir)
MATCHZY_MATCHES_SUBDIR=matches
# Base path for loading configs (relative to CS2 cfg)
MATCHZY_LOAD_BASE=cfg/MatchZy

# Sudo user for running runtime scripts
RUNTIME_SUDO_USER=cs2
# Initial delay before checking if the server is up (seconds)
RUNTIME_BOOT_DELAY_SECONDS=2.0
# Timeout for runtime subprocesses (seconds)
RUNTIME_SUBPROCESS_TIMEOUT=30
# Maximum timeout for the server to come online (seconds)
RUNTIME_START_TIMEOUT_SECONDS=30
# Grace period before considering the server offline (seconds)
RUNTIME_ONLINE_GRACE_SECONDS=30

# =============================================================================
# SERVER POOL (S1 to S5)
# =============================================================================
# Set the IDs of servers that will be active in the pool.
# Default: 1,2,3,4,5
POOL_SERVER_IDS=1,2,3,4,5

# For each server (replace N with the number: 1, 2, 3, 4, 5):
# POOL_S{N}_ENABLED=true          # Active or not
# POOL_S{N}_NAME=SERVER #01       # Display name
# POOL_S{N}_FLAG=                 # Flag emoji (e.g. 🇫🇷)
# POOL_S{N}_RUNTIME_ID=mix{N}     # Unique runtime identifier
# POOL_S{N}_START_SCRIPT=         # Startup script path
# POOL_S{N}_STOP_SCRIPT=          # Stop script path (optional)
# POOL_S{N}_SERVICE_NAME=         # systemd service name (optional)
# POOL_S{N}_TMUX_SESSION=mix{N}   # tmux session name
# POOL_S{N}_HOST=                 # Server IP address
# POOL_S{N}_PORT=                 # Game port
# POOL_S{N}_GOTV_PORT=            # GOTV port
# POOL_S{N}_RCON_PASSWORD=        # RCON password
# POOL_S{N}_MODES=mix,tourney     # Enabled modes (comma separated)
# POOL_S{N}_PICKS_TEXT_ID=        # Text channel ID for picks
# POOL_S{N}_PICKS_VOICE_ID=       # Voice channel ID for picks
# POOL_S{N}_TEAM1_VOICE_ID=       # Team 1 voice channel ID
# POOL_S{N}_TEAM2_VOICE_ID=       # Team 2 voice channel ID
# POOL_S{N}_CATEGORY_ID=          # Channel category ID

# Example for server 1:
POOL_S1_ENABLED=true
POOL_S1_NAME=SERVER #01
POOL_S1_FLAG=
POOL_S1_RUNTIME_ID=mix1
POOL_S1_START_SCRIPT=
POOL_S1_TMUX_SESSION=mix1
POOL_S1_HOST=
POOL_S1_PORT=27015
POOL_S1_GOTV_PORT=27020
POOL_S1_RCON_PASSWORD=
POOL_S1_MODES=mix,tourney
POOL_S1_PICKS_TEXT_ID=0000000000000000000
POOL_S1_PICKS_VOICE_ID=0000000000000000000
POOL_S1_TEAM1_VOICE_ID=0000000000000000000
POOL_S1_TEAM2_VOICE_ID=0000000000000000000
POOL_S1_CATEGORY_ID=0000000000000000000

# =============================================================================
# TOURNAMENT SERVERS (TS1 to TS5)
# =============================================================================
# For each tournament server (replace N with the number: 1..5):
# TS{N}_ACTIVE=false              # Active or not
# TS{N}_NAME=TOURN SERVER #0{N}   # Display name
# TS{N}_HOST=                     # IP address
# TS{N}_PORT=                     # Game port
# TS{N}_RCON_PASSWORD=            # RCON password
# TS{N}_GOTV_PORT=                # GOTV port

# Example for server 1:
TS1_ACTIVE=false
TS1_NAME=TOURN SERVER #01
TS1_HOST=
TS1_PORT=27015
TS1_RCON_PASSWORD=
TS1_GOTV_PORT=27020

# =============================================================================
# SOCIAL MEDIA URLS
# =============================================================================

WHATSAPP_GROUP_URL=
STEAM_GROUP_URL=
INSTAGRAM_URL=

# =============================================================================
# DEMO UPLOAD
# =============================================================================

# Endpoint for demo upload (optional — leave empty to disable)
DEMO_UPLOAD_URL=

# Public base URL for demo download (optional — e.g. https://your-domain.com/demos)
DEMO_DOWNLOAD_URL=

# =============================================================================
# RANKING / QUEUE
# =============================================================================

# Timezone for queue priority reset (e.g. Europe/Lisbon)
QUEUE_PRIORITY_TIMEZONE=Europe/Lisbon
# Hour of day to reset priority (0-23)
QUEUE_PRIORITY_RESET_HOUR=8
# Current season start date (YYYY-MM-DD)
SEASON_START_DATE=2026-03-01

# =============================================================================
# WEBHOOK — Stripe Integration (optional)
# =============================================================================

# HTTP webhook port for Stripe notifications
WEBHOOK_PORT=8765
